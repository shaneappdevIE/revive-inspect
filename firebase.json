{
  "hosting": {
    "public": ".",
    "ignore": [
      ".claude",
      "firebase.json",
      ".firebaserc",
      ".gitignore",
      "cors.json"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/ReviveTruckInspect(12).html"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(jpg|jpeg|png|webp|gif|svg|ico)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      }
    ]
  }
}
